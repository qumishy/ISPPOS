import React, { useEffect, useState, useCallback } from 'react';
import {
  View, Text, ScrollView, TouchableOpacity,
  StyleSheet, RefreshControl, Dimensions,
} from 'react-native';
import { useFocusEffect } from '@react-navigation/native';
import { colors, spacing, radius, fontSize } from '../theme';
import { getLocalInvoices, getLocalCollections, subscribeDataChanges } from '../services/database';
import { formatCurrency, formatNumber, formatDateShort } from '../utils/helpers';
import { Badge, Loading, ProgressBar, Row, Btn } from '../components/UI';
import SyncBar from '../components/SyncBar';
import { useAuth } from '../services/AuthContext';
import { isOnline, addSyncListener } from '../services/SyncService';

const W = Dimensions.get('window').width;

function StatCard({ value, label, icon, color }) {
  return (
    <View style={[s.statCard, { borderTopColor: color, borderTopWidth: 3 }]}>
      <Text style={s.statIcon}>{icon}</Text>
      <Text style={[s.statValue, { color }]} numberOfLines={1}>{value}</Text>
      <Text style={s.statLabel}>{label}</Text>
    </View>
  );
}

function AgentQuickAction({ label, icon, onPress, color }) {
  return (
    <TouchableOpacity style={[s.quickBtn, { borderColor: color }]} onPress={onPress} activeOpacity={0.85}>
      <Text style={s.quickIcon}>{icon}</Text>
      <Text style={s.quickText}>{label}</Text>
    </TouchableOpacity>
  );
}

function AgentDashboard({ navigation, user, invoices, collections, online }) {
  const today = new Date().toISOString().slice(0, 10);

  const todayInvoices = invoices.filter(x => String(x.invoice_date || x.created_at || '').slice(0, 10) === today);
  const todayCollections = collections.filter(x => String(x.collection_date || x.created_at || '').slice(0, 10) === today);

  const todaySales = todayInvoices.reduce((s, x) => s + Number(x.net_amount || x.total_amount || 0), 0);
  const todayCollected = todayCollections
    .filter(x => x.status === 'approved' || x.status === 'pending')
    .reduce((s, x) => s + Number(x.amount || 0), 0);

  const pendingInvoices = invoices.filter(x => x.status === 'pending');
  const pendingCollections = collections.filter(x => x.status === 'pending');

  return (
    <>
      <SyncBar />

      <View style={s.header}>
        <View>
          <Text style={s.welcome}>مرحبًا، {user?.name || '—'}</Text>
          <Text style={s.sub}>لوحة المندوب</Text>
        </View>
        <Badge status={online ? 'approved' : 'pending'} text={online ? 'أونلاين' : 'أوفلاين'} />
      </View>

      <View style={s.statsGrid}>
        <StatCard value={formatCurrency(todaySales)} label="مبيعاتي اليوم" icon="💵" color={colors.green} />
        <StatCard value={formatCurrency(todayCollected)} label="تحصيلاتي اليوم" icon="💰" color={colors.blue} />
        <StatCard value={formatNumber(pendingInvoices.length)} label="فواتيري المعلقة" icon="🧾" color={colors.orange} />
        <StatCard value={formatNumber(pendingCollections.length)} label="تحصيلاتي المعلقة" icon="📥" color={colors.purple} />
      </View>

      <View style={s.section}>
        <Text style={s.sectionTitle}>إجراءات سريعة</Text>
        <View style={s.quickWrap}>
          <AgentQuickAction
            label="فاتورة جديدة"
            icon="🧾"
            color={colors.green}
            onPress={() => navigation.navigate('NewInvoice')}
          />
          <AgentQuickAction
            label="تحصيل جديد"
            icon="💰"
            color={colors.blue}
            onPress={() => navigation.navigate('NewCollection')}
          />
        </View>
      </View>

      <View style={s.section}>
        <Row style={s.sectionHead}>
          <Text style={s.sectionTitle}>آخر فواتيري</Text>
          <TouchableOpacity onPress={() => navigation.navigate('Invoices')}>
            <Text style={s.link}>عرض الكل</Text>
          </TouchableOpacity>
        </Row>

        {invoices.slice(0, 5).length === 0 ? (
          <Text style={s.empty}>لا توجد فواتير</Text>
        ) : invoices.slice(0, 5).map(inv => (
          <TouchableOpacity
            key={inv.id}
            style={s.card}
            onPress={() => navigation.navigate('InvoiceDetail', { id: inv.id })}
          >
            <Row style={{ justifyContent: 'space-between', marginBottom: 6 }}>
              <Text style={s.cardTitle}>{inv.invoice_number || '—'}</Text>
              <Badge status={inv.status} />
            </Row>
            <Text style={s.cardSub}>{inv.pos_customers?.name || '—'}</Text>
            <Row style={{ justifyContent: 'space-between', marginTop: 8 }}>
              <Text style={s.amount}>{formatCurrency(inv.net_amount || inv.total_amount || 0)}</Text>
              <Text style={s.date}>{formatDateShort(inv.invoice_date || inv.created_at)}</Text>
            </Row>
          </TouchableOpacity>
        ))}
      </View>

      <View style={s.section}>
        <Row style={s.sectionHead}>
          <Text style={s.sectionTitle}>آخر تحصيلاتي</Text>
          <TouchableOpacity onPress={() => navigation.navigate('Collections')}>
            <Text style={s.link}>عرض الكل</Text>
          </TouchableOpacity>
        </Row>

        {collections.slice(0, 5).length === 0 ? (
          <Text style={s.empty}>لا توجد تحصيلات</Text>
        ) : collections.slice(0, 5).map(col => (
          <View key={col.id} style={s.card}>
            <Row style={{ justifyContent: 'space-between', marginBottom: 6 }}>
              <Text style={s.cardTitle}>{col.collection_number || '—'}</Text>
              <Badge status={col.status} />
            </Row>
            <Text style={s.cardSub}>{col.pos_customers?.name || '—'}</Text>
            <Row style={{ justifyContent: 'space-between', marginTop: 8 }}>
              <Text style={s.amount}>{formatCurrency(col.amount || 0)}</Text>
              <Text style={s.date}>{formatDateShort(col.collection_date || col.created_at)}</Text>
            </Row>
          </View>
        ))}
      </View>
    </>
  );
}

function AdminDashboard({ navigation, user, invoices, collections, online }) {
  const totalSales = invoices.reduce((s, x) => s + Number(x.net_amount || x.total_amount || 0), 0);
  const totalCollected = collections
    .filter(x => x.status === 'approved')
    .reduce((s, x) => s + Number(x.amount || 0), 0);

  const pendingInv = invoices.filter(x => x.status === 'pending').length;
  const pendingCol = collections.filter(x => x.status === 'pending').length;

  return (
    <>
      <SyncBar />

      <View style={s.header}>
        <View>
          <Text style={s.welcome}>مرحبًا، {user?.name || '—'}</Text>
          <Text style={s.sub}>لوحة التحكم</Text>
        </View>
        <Badge status={online ? 'approved' : 'pending'} text={online ? 'أونلاين' : 'أوفلاين'} />
      </View>

      <View style={s.statsGrid}>
        <StatCard value={formatCurrency(totalSales)} label="إجمالي المبيعات" icon="💵" color={colors.green} />
        <StatCard value={formatCurrency(totalCollected)} label="المحصّل" icon="💰" color={colors.blue} />
        <StatCard value={formatNumber(pendingInv)} label="فواتير معلقة" icon="🧾" color={colors.orange} />
        <StatCard value={formatNumber(pendingCol)} label="قبوض معلقة" icon="📥" color={colors.purple} />
      </View>

      <View style={s.section}>
        <Row style={s.sectionHead}>
          <Text style={s.sectionTitle}>أحدث الفواتير</Text>
          <TouchableOpacity onPress={() => navigation.navigate('Invoices')}>
            <Text style={s.link}>عرض الكل</Text>
          </TouchableOpacity>
        </Row>

        {invoices.slice(0, 5).length === 0 ? (
          <Text style={s.empty}>لا توجد فواتير</Text>
        ) : invoices.slice(0, 5).map(inv => (
          <TouchableOpacity
            key={inv.id}
            style={s.card}
            onPress={() => navigation.navigate('InvoiceDetail', { id: inv.id })}
          >
            <Row style={{ justifyContent: 'space-between', marginBottom: 6 }}>
              <Text style={s.cardTitle}>{inv.invoice_number || '—'}</Text>
              <Badge status={inv.status} />
            </Row>
            <Text style={s.cardSub}>{inv.pos_customers?.name || '—'}</Text>
            <Row style={{ justifyContent: 'space-between', marginTop: 8 }}>
              <Text style={s.amount}>{formatCurrency(inv.net_amount || inv.total_amount || 0)}</Text>
              <Text style={s.date}>{formatDateShort(inv.invoice_date || inv.created_at)}</Text>
            </Row>
          </TouchableOpacity>
        ))}
      </View>

      <View style={s.section}>
        <Row style={s.sectionHead}>
          <Text style={s.sectionTitle}>التحصيلات المعلقة</Text>
          <TouchableOpacity onPress={() => navigation.navigate('Collections')}>
            <Text style={s.link}>عرض الكل</Text>
          </TouchableOpacity>
        </Row>

        {collections.filter(x => x.status === 'pending').slice(0, 5).length === 0 ? (
          <Text style={s.empty}>لا توجد تحصيلات معلقة</Text>
        ) : collections.filter(x => x.status === 'pending').slice(0, 5).map(col => (
          <View key={col.id} style={s.card}>
            <Row style={{ justifyContent: 'space-between', marginBottom: 6 }}>
              <Text style={s.cardTitle}>{col.collection_number || '—'}</Text>
              <Badge status={col.status} />
            </Row>
            <Text style={s.cardSub}>{col.pos_customers?.name || '—'}</Text>
            <Row style={{ justifyContent: 'space-between', marginTop: 8 }}>
              <Text style={s.amount}>{formatCurrency(col.amount || 0)}</Text>
              <Text style={s.date}>{formatDateShort(col.collection_date || col.created_at)}</Text>
            </Row>
          </View>
        ))}
      </View>
    </>
  );
}

export default function DashboardScreen({ navigation }) {
  const { user } = useAuth();
  const isAgent = user?.role === 'agent';

  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [online, setOnline] = useState(isOnline());
  const [invoices, setInvoices] = useState([]);
  const [collections, setCollections] = useState([]);

  const load = useCallback(async () => {
    try {
      setOnline(isOnline());

      const invoiceFilters = isAgent ? { agent_id: user?.id } : {};
      const collectionFilters = isAgent ? { agent_id: user?.id } : {};

      const inv = await getLocalInvoices(invoiceFilters);
      const col = await getLocalCollections(collectionFilters);

      setInvoices(Array.isArray(inv) ? inv : []);
      setCollections(Array.isArray(col) ? col : []);
    } catch (e) {
      console.log('Dashboard load error:', e.message);
      setInvoices([]);
      setCollections([]);
    } finally {
      setLoading(false);
      setRefreshing(false);
    }
  }, [isAgent, user?.id]);

  useEffect(() => {
    load();

    const unsubSync = addSyncListener(() => {
      setOnline(isOnline());
      load();
    });

    const unsubData = subscribeDataChanges(() => {
      load();
    });

    return () => {
      unsubSync?.();
      unsubData?.();
    };
  }, [load]);

  useFocusEffect(
    useCallback(() => {
      load();
    }, [load])
  );

  const onRefresh = () => {
    setRefreshing(true);
    load();
  };

  if (loading) return <Loading />;

  return (
    <ScrollView
      style={s.screen}
      contentContainerStyle={{ paddingBottom: 60 }}
      refreshControl={<RefreshControl refreshing={refreshing} onRefresh={onRefresh} />}
    >
      {isAgent ? (
        <AgentDashboard
          navigation={navigation}
          user={user}
          invoices={invoices}
          collections={collections}
          online={online}
        />
      ) : (
        <AdminDashboard
          navigation={navigation}
          user={user}
          invoices={invoices}
          collections={collections}
          online={online}
        />
      )}
    </ScrollView>
  );
}

const s = StyleSheet.create({
  screen: { flex: 1, backgroundColor: colors.bg },
  header: {
    paddingHorizontal: spacing.md,
    paddingTop: spacing.sm,
    paddingBottom: spacing.md,
    flexDirection: 'row',
    justifyContent: 'space-between',
    alignItems: 'center',
  },
  welcome: { color: colors.t1, fontSize: fontSize.xl, fontWeight: '800' },
  sub: { color: colors.t3, marginTop: 4 },
  statsGrid: {
    flexDirection: 'row',
    flexWrap: 'wrap',
    paddingHorizontal: spacing.md,
    gap: spacing.sm,
  },
  statCard: {
    width: (W - spacing.md * 2 - spacing.sm) / 2,
    backgroundColor: colors.card,
    borderRadius: radius.lg,
    padding: spacing.md,
  },
  statIcon: { fontSize: 24, marginBottom: 8 },
  statValue: { fontSize: fontSize.xl, fontWeight: '800' },
  statLabel: { color: colors.t3, marginTop: 4, fontSize: fontSize.sm },
  section: { paddingHorizontal: spacing.md, marginTop: spacing.lg },
  sectionHead: { justifyContent: 'space-between', marginBottom: spacing.sm },
  sectionTitle: { color: colors.t1, fontSize: fontSize.lg, fontWeight: '800' },
  link: { color: colors.blue, fontWeight: '700' },
  card: {
    backgroundColor: colors.card,
    borderRadius: radius.lg,
    padding: spacing.md,
    marginBottom: spacing.sm,
  },
  cardTitle: { color: colors.t1, fontWeight: '800', fontSize: fontSize.md },
  cardSub: { color: colors.t3 },
  amount: { color: colors.green, fontWeight: '800' },
  date: { color: colors.t3, fontSize: fontSize.xs },
  empty: { color: colors.t3, textAlign: 'center', paddingVertical: spacing.lg },
  quickWrap: {
    flexDirection: 'row',
    gap: spacing.sm,
  },
  quickBtn: {
    flex: 1,
    backgroundColor: colors.card,
    borderRadius: radius.lg,
    paddingVertical: 14,
    paddingHorizontal: 12,
    borderWidth: 1,
    alignItems: 'center',
    justifyContent: 'center',
  },
  quickIcon: {
    fontSize: 22,
    marginBottom: 6,
  },
  quickText: {
    color: colors.t1,
    fontWeight: '800',
  },
});
