import React from 'react';
import { createDrawerNavigator } from '@react-navigation/drawer';
import { createStackNavigator } from '@react-navigation/stack';

import { InvoicesScreen } from '../screens/MainScreens';
import CollectionsScreen from '../screens/CollectionsScreen';
import NewInvoiceScreen from '../screens/NewInvoiceScreen';
import NewCollectionScreen from '../screens/NewCollectionScreen';

const Drawer = createDrawerNavigator();
const Stack = createStackNavigator();

function InvoicesStack() {
  return (
    <Stack.Navigator>
      <Stack.Screen
        name="InvoicesHome"
        component={InvoicesScreen}
        options={{ title: 'الفواتير' }}
      />
      <Stack.Screen
        name="NewInvoice"
        component={NewInvoiceScreen}
        options={{ title: 'فاتورة جديدة' }}
      />
    </Stack.Navigator>
  );
}

function CollectionsStack() {
  return (
    <Stack.Navigator>
      <Stack.Screen
        name="CollectionsHome"
        component={CollectionsScreen}
        options={{ title: 'التحصيلات' }}
      />
      <Stack.Screen
        name="NewCollection"
        component={NewCollectionScreen}
        options={{ title: 'تحصيل جديد' }}
      />
    </Stack.Navigator>
  );
}

export default function AdminDrawerNavigator() {
  return (
    <Drawer.Navigator
      screenOptions={{
        headerShown: false,
      }}
    >
      <Drawer.Screen
        name="InvoicesDrawer"
        component={InvoicesStack}
        options={{ title: 'الفواتير', drawerLabel: 'الفواتير' }}
      />
      <Drawer.Screen
        name="CollectionsDrawer"
        component={CollectionsStack}
        options={{ title: 'التحصيلات', drawerLabel: 'التحصيلات' }}
      />
    </Drawer.Navigator>
  );
}
