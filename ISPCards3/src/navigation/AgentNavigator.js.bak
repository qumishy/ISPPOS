import React from 'react';
import { createStackNavigator } from '@react-navigation/stack';

import AgentDashboardScreen from '../screens/agent/AgentDashboardScreen';
import { InvoicesScreen, CollectionsScreen } from '../screens/MainScreens';
import { NewInvoiceScreen, NewCollectionScreen } from '../screens/FormScreens';

const Stack = createStackNavigator();

export default function AgentNavigator() {
  return (
    <Stack.Navigator
      initialRouteName="AgentDashboard"
      screenOptions={{ headerShown: true }}
    >
      <Stack.Screen
        name="AgentDashboard"
        component={AgentDashboardScreen}
        options={{ title: 'لوحة المندوب' }}
      />

      <Stack.Screen
        name="Invoices"
        component={InvoicesScreen}
        options={{ title: 'الفواتير' }}
      />

      <Stack.Screen
        name="Collections"
        component={CollectionsScreen}
        options={{ title: 'التحصيلات' }}
      />

      <Stack.Screen
        name="NewInvoice"
        component={NewInvoiceScreen}
        options={{ title: 'فاتورة جديدة' }}
      />

      <Stack.Screen
        name="NewCollection"
        component={NewCollectionScreen}
        options={{ title: 'تحصيل جديد' }}
      />
    </Stack.Navigator>
  );
}
